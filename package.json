{
  "name": "holly-super-agent",
  "version": "1.0.1-SOVEREIGN",
  "description": "HOLLY - Hyper-Optimized Logic & Learning Yield - Autonomous AI Development Partner [DEPLOY_HEARTBEAT: 2026-04-30_19:16]",
  "__IMPORTANT_NOTE__": "DO NOT upgrade tailwindcss to v4+ - it requires @tailwindcss/postcss. Keep at v3.4.1",
  "main": "index.js",
  "scripts": {
    "postinstall": "prisma generate && node -e \"const fs=require('fs'),p='node_modules/@prisma/client/.prisma'; if(!fs.existsSync(p)){fs.symlinkSync('../../.prisma',p,'junction')}\"",
    "dev": "ts-node --project tsconfig.server.json server.ts",
    "build": "npm run compile-server && prisma generate && NODE_OPTIONS=\"--max-old-space-size=3072\" next build",
    "generate-architecture": "npx ts-node --transpile-only scripts/generate-architecture.ts",
    "start": "node holly-server.js",
    "lint": "next lint",
    "scan": "node .holly/tools/comprehensive-scanner.js",
    "scan:basic": "node .holly/tools/typescript-scanner.js",
    "pre-deploy": "npm run scan && npx prisma validate",
    "safe-deploy": "npm run pre-deploy && npm run build",
    "test": "npx jest --passWithNoTests",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage --passWithNoTests",
    "setup:db": "ts-node setup-database.ts",
    "seed:db": "ts-node database-seed.ts",
    "migrate:db": "psql $DATABASE_URL -f database-schema.sql",
    "compile-server": "tsc --project tsconfig.server.json"
  },
  "keywords": [
    "ai",
    "development",
    "automation",
    "code-generation",
    "deployment",
    "github",
    "emotional-intelligence"
  ],
