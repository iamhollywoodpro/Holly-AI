// ============================================================================
// PHASE 7 — PUBLIC API LAYER
// ============================================================================

/// API key issued to a user for programmatic access to the HOLLY API.
/// The `keyHash` field stores a SHA-256 hex digest of the raw key so the
/// plaintext is never stored.  The raw key is returned ONCE at creation.
model ApiKey {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String // human label, e.g. "My App"
  keyHash   String    @unique // SHA-256(rawKey) — never store plaintext
  keyPrefix String // first 8 chars of raw key for display ("holly_ab12")
  scopes    String[]  @default([]) // e.g. ["chat", "evolution:read"]
  isActive  Boolean   @default(true)
  expiresAt DateTime? // null = never expires

  // Rate limiting (requests per minute, per day)
  rpmLimit Int @default(20)
  rpdLimit Int @default(1000)

  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  usageLogs ApiKeyUsage[]

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

/// Canva OAuth tokens — one row per HOLLY user, stores access + refresh tokens.
model CanvaToken {
  id           String   @id @default(cuid())
  userId       String   @unique // HOLLY user id (maps to User.id)
  accessToken  String   @db.Text // Canva short-lived access token
  refreshToken String   @db.Text // Canva long-lived refresh token (single-use)
  expiresAt    DateTime // When the current access token expires
  scope        String // Space-separated scopes granted
  canvaUserId  String? // Canva user id (from /v1/users/me)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("canva_tokens")
}

/// Per-request usage log for an ApiKey — used for rate limiting and analytics.
model ApiKeyUsage {
  id       String @id @default(cuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  endpoint   String // e.g. "/api/v1/chat"
  method     String   @default("POST")
  statusCode Int      @default(200)
  durationMs Int      @default(0)
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([apiKeyId])
  @@index([apiKeyId, createdAt])
  @@map("api_key_usage")
}

