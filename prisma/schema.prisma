// Problems detected by HOLLY's self-monitoring system
model DetectedProblem {
  id String @id @default(cuid())

  // Problem classification
  type     String // 'performance', 'error', 'ux', 'code_quality', 'security'
  severity String // 'low', 'medium', 'high', 'critical'

  // Problem details
  title       String
  description String @db.Text
  evidence    Json // { logs: [], metrics: {}, affectedComponents: [] }
  impact      String // User-facing impact description

  // Status tracking
  status     String    @default("detected") // 'detected', 'analyzing', 'resolved', 'ignored'
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?

  // Relationships
  hypotheses Hypothesis[]

  @@index([status, severity])
  @@index([detectedAt])
  @@index([type])
  @@map("detected_problems")
}

// Solution hypotheses generated by HOLLY
model Hypothesis {
  id String @id @default(cuid())

  // Related problem
  problemId String
  problem   DetectedProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  // Hypothesis details
  proposedSolution String @db.Text
  reasoning        String @db.Text
  expectedImpact   String
  confidence       Float // 0-100

  // Testing and risks
  testingStrategy String @db.Text
  risks           Json // Array of risk strings

  // Implementation plan
  implementation Json // { filesAffected: [], complexity: 'low/medium/high', dependencies: [] }

  // Testing results
  tested      Boolean @default(false)
  testResults Json? // Metrics if tested

  // Timestamps
  createdAt DateTime @default(now())

  // Relationships
  experiences Experience[]

  @@index([problemId])
  @@index([confidence])
  @@index([tested])
  @@map("hypotheses")
}

// Learning experiences from deployments and fixes
model Experience {
  id String @id @default(cuid())

  // Related hypothesis (optional - some experiences don't come from hypotheses)
  hypothesisId String?
  hypothesis   Hypothesis? @relation(fields: [hypothesisId], references: [id])

  // Experience classification
  type    String // 'deployment', 'fix', 'feature', 'optimization', 'refactor'
  action  String @db.Text // What was done
  context Json // { situation: '', problem: '', constraints: [] }

  // Outcome tracking
  outcome String // 'success', 'failure', 'partial'
  results Json // { errorRate: 0.01, responseTime: 250, userFeedback: 'positive' }

  // Learning
  lessonsLearned String  @db.Text
  wouldRepeat    Boolean // Would we do this again?
  confidence     Float // 0-100, how confident in this approach

  // Timestamps
  createdAt DateTime @default(now())

  @@index([type, outcome])
  @@index([createdAt])
  @@index([wouldRepeat])
  @@index([hypothesisId])
  @@map("experiences")
}

