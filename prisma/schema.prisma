/// A builder workspace session — one per user build request.
model BuildSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request
  prompt      String @db.Text
  projectType String @default("webapp") // webapp, api, landing, saas, tool
  stack       String @default("nextjs") // nextjs, react, node, python, static

  // State
  status   String @default("idle") // idle, planning, building, running, error, done, stopped
  phase    String @default("init") // init, inspect, plan, scaffold, install, build, verify, fix, done
  progress Int    @default(0) // 0-100

  // Workspace
  workspaceDir String? // abs path to isolated sandbox dir
  previewUrl   String? // detected preview URL
  previewPort  Int? // detected port
  repoUrl      String? // connected git repo
  branch       String?

  // Results
  plan       String? @db.Text // JSON build plan
  summary    String? @db.Text
  errorCount Int     @default(0)
  fixCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    BuildEvent[]
  files     BuildFile[]
  processes BuildProcess[]
  sandbox   BuildSandbox?
  terminals BuildTerminal[]
  preview   BuildPreview?

  // Phase 12 extended fields
  sandboxProvider      String? // local|docker
  sandboxId            String? // container id if docker
  lastErrorFingerprint String? // for fix-loop dedup
  fixAttempts          Int     @default(0)

  @@index([userId])
  @@index([status])
  @@map("build_sessions")
}

/// Streamed event log for a build session — drives the UI activity feed.
model BuildEvent {
  id        String       @id @default(cuid())
  sessionId String
  session   BuildSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type       String // plan|file_write|file_delete|cmd_start|cmd_done|log|error|fix|preview_ready|done|info
  phase      String?
  title      String
  body       String? @db.Text
  filePath   String?
  command    String?
  exitCode   Int?
  durationMs Int?
  level      String  @default("info") // info|warn|error|success

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("build_events")
}

/// File snapshot for a build session (tracks what HOLLY wrote/changed).
model BuildFile {
  id        String       @id @default(cuid())
  sessionId String
  session   BuildSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  path      String
  content   String  @db.Text
  action    String  @default("write") // write|delete|patch
  language  String?
  diffPatch String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, path])
  @@index([sessionId])
  @@map("build_files")
}

/// Running process tracker (dev servers, build tasks).
model BuildProcess {
  id        String       @id @default(cuid())
  sessionId String
  session   BuildSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  pid     Int?
  command String
  cwd     String?
  status  String  @default("starting") // starting|running|stopped|crashed
  port    Int?
  logs    String? @db.Text

  startedAt DateTime  @default(now())
  stoppedAt DateTime?

  @@index([sessionId])
  @@map("build_processes")
}

// ─── Builder: Extended models for Phase 12 upgrades ───────────────────────────

/// Sandbox provider metadata — tracks which provider was used and cleanup state.
model BuildSandbox {
