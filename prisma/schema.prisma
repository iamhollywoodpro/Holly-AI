  @@index([userId])
  @@index([projectId])
  @@index([platform])
  @@index([status])
  @@index([environment])
  @@index([startedAt])
  @@map("lifecycle_deployments")
}

model MonitoringAlert {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String
  project         LifecycleProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            String
  severity        String            @default("warning")
  title           String
  description     String?           @db.Text
