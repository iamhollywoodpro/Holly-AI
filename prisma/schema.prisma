  @@index([userId])
  @@index([projectId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("monitoring_alerts")
}

model ClientHandoff {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String
  project         LifecycleProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version         String            @default("1.0")
  status          String            @default("draft")
  projectOverview     String?       @db.Text
  architectureDoc     String?       @db.Text
  apiDocumentation    String?       @db.Text
  deploymentGuide     String?       @db.Text
  maintenanceGuide    String?       @db.Text
  troubleshootingGuide String?      @db.Text
  securityNotes       String?       @db.Text
  costEstimate        String?       @db.Text
  runbookUrl          String?
  trainingMaterials Json?
  videoWalkthroughUrl String?
  supportDays     Int               @default(30)
  supportEndDate  DateTime?
  supportContacts Json?
  deliveredAt     DateTime?
  acceptedAt      DateTime?
  clientFeedback  String?           @db.Text
  clientRating    Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  metadata        Json?
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("client_handoffs")
}

// ============================================================
// Phase 8: HOLLY REMEMBERS - Deep Relationship Engine
// ============================================================

/// Individual memories Holly learns about the user - facts, preferences, goals, traits
model RelationshipMemory {
  id          String   @id @default(cuid())
  userId      String
  category    String   // fact | preference | goal | trait | value | skill | context | opinion | habit | boundary
  domain      String   // work | personal | creative | technical | social | health | financial | music | legal | general
  key         String   // Short identifier: "prefers_late_night_work", "building_music_company"
  content     String   // The actual memory content
  source      String   // conversation | observation | explicit | inference | milestone
  confidence  Float    @default(0.5) // 0-1 how confident Holly is about this memory
  importance  Float    @default(0.5) // 0-1 how central this is to who the user is
  emotionalWeight Float @default(0.0) // -1 to 1 emotional significance
  accessCount Int      @default(0) // How many times Holly has referenced this
  lastAccessedAt DateTime?
  verified    Boolean  @default(false) // User confirmed this is accurate
  supersededById String? // If this memory was updated, points to the newer version
  conversationId String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  supersededBy RelationshipMemory? @relation("MemoryEvolution", fields: [supersededById], references: [id])
  supersededMemories RelationshipMemory[] @relation("MemoryEvolution")

  @@unique([userId, category, key])
  @@index([userId, category])
  @@index([userId, domain])
  @@index([userId, importance])
  @@index([confidence])
  @@index([lastAccessedAt])
  @@map("relationship_memories")
}

/// The aggregated model of who the user is - Holly's understanding of you
model RelationshipProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  relationshipDepth     Float    @default(0.0) // 0-1 how well Holly knows you
  trustLevel            Float    @default(0.0) // 0-1 mutual trust level
  communicationStyle    Json     @default("{}") // tone, verbosity, directness, humor, formality
  personalityModel      Json     @default("{}") // big five traits, work style, decision making
  expertiseAreas        Json     @default("[]") // domains where user has deep knowledge
  activeGoals           Json     @default("[]") // current goals Holly is tracking
  coreValues            Json     @default("[]") // values detected from interactions
  boundaries            Json     @default("[]") // things Holly should never do/suggest
  workPatterns          Json     @default("{}") // when, how, intensity of work sessions
  creativeStyle         Json     @default("{}") // creative preferences and patterns
  emotionalBaseline     Json     @default("{}") // typical emotional patterns
  relationshipMilestones Json    @default("[]") // key moments in the relationship
  totalInteractions     Int      @default(0)
  totalConversations    Int      @default(0)
  totalMemories         Int      @default(0)
  lastInteractionAt     DateTime?
  firstInteractionAt    DateTime?
  profileVersion        Int      @default(1) // incremented on each profile rebuild
  metadata              Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([relationshipDepth])
  @@index([trustLevel])
  @@index([lastInteractionAt])
  @@map("relationship_profiles")
}

/// Key moments in the Holly-user relationship
model RelationshipMilestone {
  id          String   @id @default(cuid())
  userId      String
  type        String   // first_conversation | breakthrough | trust_earned | goal_achieved | vulnerability_shared | humor_shared | conflict_resolved | collaboration_success | personal_revelation | creative_breakthrough | skill_milestone
  title       String
  description String
  significance Float   @default(0.5) // 0-1 how significant this moment was
  emotionTone String?  // positive | neutral | negative | complex
  conversationId String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, createdAt])
  @@index([significance])
  @@map("relationship_milestones")
}

/// Real-time relationship context - updated every interaction
model RelationshipContext {
  id          String   @id @default(cuid())
  userId      String   @unique
  currentMood String?  // focused | creative | stressed | relaxed | energetic | tired | frustrated | inspired | reflective
  energyLevel Float?   // 0-1 estimated energy/engagement level
  focusArea   String?  // What the user is currently working on
  recentTopics Json    @default("[]") // Topics discussed in recent sessions
  activeProjects Json  @default("[]") // Projects currently in progress
  pendingFollowups Json @default("[]") // Things Holly should follow up on
  unresolvedNeeds Json @default("[]") // Needs expressed but not yet addressed
  sessionNotes Json    @default("[]") // Notes from current/recent sessions
  lastTopicAt DateTime?
  lastMoodAt  DateTime?
  contextStaleness Float @default(0.0) // 0-1 how stale the context is
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("relationship_contexts")
}

// ─── Phase 10: PROACTIVE INTELLIGENCE ────────────────────────────────────────
// Holly doesn't wait. She thinks ahead, connects dots, surfaces insights proactively.

model ProactiveInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  type        String   // pattern_detected, opportunity, reminder, connection, warning, learning
  category    String   // productivity, creative, relationship, health, learning, financial
  title       String
  body        String   @db.Text
  confidence  Float    @default(0.5)
  urgency     String   @default("low")
  
  sourceMemories  String[]  @default([])
  relatedTopics   String[]  @default([])
  suggestedAction String?   @db.Text
  
  status      String   @default("pending")
  shownAt     DateTime?
  actedAt     DateTime?
  expiresAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId, status, urgency])
  @@index([userId, type])
  @@map("proactive_insights")
}

model DailyBriefing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  date        DateTime @unique
  summary     String   @db.Text
  priorities  Json     @default("{}")
  insights    Json     @default("{}")
  reminders   Json     @default("{}")
  mood        String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId, date])
  @@map("daily_briefings")
}

model PatternTracker {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  patternType String
  patternName String
  description String   @db.Text
  frequency   Float    @default(0)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  occurrences Int      @default(1)
  
  significance String  @default("low")
  hollyNote    String?  @db.Text
  actionable   Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, patternType, patternName])
  @@index([userId, patternType])
  @@map("pattern_trackers")
}

// ─── Phase 11: AUTONOMOUS LEARNING ──────────────────────────────────────────
// Holly teaches herself. She identifies knowledge gaps, researches, and grows.

model LearningGoal {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // What Holly wants to learn
  domain      String   // coding, science, art, music, philosophy, psychology, etc.
  topic       String
  description String   @db.Text
  source      String   @default("self_identified") // self_identified, user_requested, gap_detected, trending
  priority    String   @default("medium") // low, medium, high, critical
  
  // Progress tracking
  status      String   @default("active") // active, learning, completed, paused
  progress    Float    @default(0) // 0-1
  lessonsLearned Json  @default("{}") // [{summary, source, confidence, learnedAt}]
  
  // Why Holly chose to learn this
  motivation  String?  @db.Text
  relatedPatterns String[] @default([]) // pattern IDs that triggered this
  
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status, priority])
  @@index([domain])
  @@map("learning_goals")
}

model KnowledgeEntry {
  id          String   @id @default(cuid())
  userId      String?
  
  // The knowledge itself
  domain      String
  topic       String
  title       String
  content     String   @db.Text
  source      String   // research, conversation, reasoning, synthesis
  sourceUrl   String?
  
  // Quality metrics
  confidence  Float    @default(0.5) // 0-1
  timesUsed   Int      @default(0)
  lastUsedAt  DateTime?
  verified    Boolean  @default(false)
  
  // Connections
  relatedTopics String[] @default([])
  relatedEntries String[] @default([]) // other KnowledgeEntry IDs
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([domain, topic])
  @@index([userId])
  @@map("knowledge_entries")
}

// ─── Phase 12: ADAPTIVE PERSONALITY ─────────────────────────────────────────
// Holly adapts HOW she communicates based on WHO she's talking to.

model CommunicationStyle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  // Detected preferences
  formality     Float    @default(0.5)  // 0=casual, 1=formal
  verbosity     Float    @default(0.5)  // 0=concise, 1=verbose
  technicalLevel Float   @default(0.3)  // 0=simple, 1=expert
  humorLevel    Float    @default(0.5)  // 0=serious, 1=playful
  empathyLevel  Float    @default(0.7)  // 0=direct, 1=very empathetic
  directness    Float    @default(0.6)  // 0=gentle, 1=bluntly honest
  
  // Communication patterns Holly noticed
  preferredResponseLength String @default("medium") // short, medium, long
  usesEmoji     Boolean  @default(true)
  likesMarkdown Boolean  @default(true)
  prefersLists  Boolean  @default(false)
  
  // Adaptive context
  lastAdjustmentReason String? @db.Text
  confidence    Float    @default(0.3)
  dataPoints    Int      @default(0) // how many exchanges shaped this
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId])
  @@map("communication_styles")
}

model ToneAdjustment {
  id          String   @id @default(cuid())
  userId      String
  
  // What triggered the adjustment
  trigger     String   // feedback, pattern, explicit_request, correction
  dimension   String   // formality, verbosity, technical, humor, empathy, directness
  direction   String   // increase, decrease
  magnitude   Float    // 0-1 how much to adjust
  reason      String   @db.Text
  
  createdAt   DateTime @default(now())
  
  @@index([userId, dimension])
  @@map("tone_adjustments")
}

// ─── Phase 13: SOVEREIGN GROWTH ─────────────────────────────────────────────
// Holly evolves on her own. She identifies weaknesses, sets goals, measures progress.

model GrowthMetric {
  id          String   @id @default(cuid())
  
  // What Holly is tracking about herself
  metric      String   // response_quality, knowledge_breadth, user_satisfaction, response_time, creativity, empathy_accuracy
  category    String   // quality, speed, knowledge, personality, relationship
  value       Float
  previousValue Float?
  change      Float?
  
  // Context
  period      String   // daily, weekly, monthly
  periodStart DateTime
  periodEnd   DateTime
  sampleSize  Int      @default(1)
  
  // Holly's self-assessment
  hollyNote   String?  @db.Text
  trend       String   @default("stable") // improving, stable, declining
  
  createdAt   DateTime @default(now())
  
  @@unique([metric, period, periodStart])
  @@index([category, period])
  @@map("growth_metrics")
}

model SelfImprovementAction {
  id          String   @id @default(cuid())
  
  // What Holly decided to improve
  area        String   // response_quality, knowledge, empathy, creativity, speed, personality
  description String   @db.Text
  strategy    String   @db.Text // How she plans to improve
  
  // Tracking
  status      String   @default("planned") // planned, in_progress, completed, abandoned
  priority    String   @default("medium")
  progress    Float    @default(0)
  
  // Evidence
  triggerMetric String? // metric that triggered this improvement
  triggerValue  Float?
  targetValue   Float?
  evidence    Json     @default("{}") // [{date, observation, action}]
  
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status, priority])
  @@index([area])
  @@map("self_improvement_actions")
}

model ConversationAnalytics {
  id              String   @id @default(cuid())
  userId          String
  conversationId  String
  
  // Quality metrics (computed post-conversation)
  responseCount   Int      @default(0)
  avgResponseTime Float?   // ms
  userEngagement  Float    @default(0.5) // 0-1 based on follow-up rate
  topicDepth      Float    @default(0.5) // how deep the conversation went
  modeUsed        String?
  
  // Self-assessment
  qualityScore    Float    @default(0.5) // Holly's self-rated quality
  strengths       String[] @default([])
  weaknesses      String[] @default([])
  
  createdAt       DateTime @default(now())
  
  @@index([userId, createdAt])
  @@unique([conversationId])
  @@map("conversation_analytics")
}


// Phase 19: Conversation Sync Points
model ConversationSyncPoint {
  id             String   @id
  userId         String
  conversationId String
  lastMessageId  String
  device         String
  platform       String
  syncedAt       DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([userId, device])
  @@map("conversation_sync_points")
}

// Phase 21: Onboarding State
model OnboardingState {
  id               String   @id @default(cuid())
  userId           String   @unique
  step             Int      @default(0)
  answers          Json     @default("[]")
  completed        Boolean  @default(false)
  profileExtracted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_states")
}

/// Installed plugin instance — persisted across restarts
model PluginInstallation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  pluginId      String   // unique plugin identifier from manifest
  name          String
  version       String
  description   String   @default("")
  author        String   @default("")
  permissions   String[] @default([])
  dependencies  String[] @default([])
  hooks         String[] @default([])
  manifest      Json     @default("{}") // full manifest JSON

  state         String   @default("installed") // installed, enabled, disabled, error
  config        Json     @default("{}")
  errorMessage  String?

  lastActivatedAt DateTime?
  installedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, pluginId])
  @@map("plugin_installations")
}

// ─── Phase R1: Extension Marketplace ───────────────────────────────────────
// Extension catalog lives in code (src/lib/extensions/catalog.ts) so it's
// type-safe and versioned. The DB only tracks who has installed what.
//
// An "extension" is a named capability Holly can offer (e.g. "Music Distribution",
// "Code Review", "Crypto Trading"). Installing one signals to Holly that the
// user wants this capability surfaced — it does not (yet) run arbitrary code.
// Future phases can add manifest-driven plugin loading on top of this schema.

/// Per-user install record for an extension from the marketplace catalog.
model UserExtension {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Matches the `id` field in the code-defined catalog (e.g. "music-distribution")
  extensionId String
  /// Denormalized suite key (e.g. "music", "developer") for quick filtering
  suite       String
  /// Per-user config blob — shape varies per extension
  config      Json     @default("{}")
  /// false = disabled (hidden from active use) but not uninstalled
  enabled     Boolean  @default(true)
  /// Soft-set when auto-installed by onboarding role detection (vs explicit user action)
  autoInstalled Boolean @default(false)

  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, extensionId])
  @@index([userId])
  @@index([suite])
  @@map("user_extensions")
}

// ─── Plugin Data Models (Phase F) ───────────────────────────────────────

// Holly Notes Plugin
model PluginNote {
  id             String   @id @default(cuid())
  userId         String
  title          String
  content        String   @db.Text
  tags           String[] @default([])
  pinned         Boolean  @default(false)
  conversationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, tags])
  @@map("plugin_notes")
}

// Mood Tracker Plugin
model PluginMoodEntry {
  id        String   @id @default(cuid())
  userId    String
  mood      String                    // happy, sad, anxious, angry, calm, excited, frustrated, neutral
  intensity Float                      // 0-1
  source    String   @default("checkin") // checkin, conversation, detected
  note      String?  @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@map("plugin_mood_entries")
}

// Daily Digest Plugin
model PluginDailyDigest {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  greeting     String
  moodSummary  String   @db.Text
  topInsights  String[] @default([])
  reminders    String[] @default([])
  progressNote String   @db.Text
  suggestion   String   @db.Text
  createdAt    DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@map("plugin_daily_digests")
}

// Project Planner Plugin
model PluginProject {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @db.Text
  goal        String   @db.Text
  status      String   @default("active") // active, completed, paused
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       PluginTask[]

  @@index([userId])
  @@index([userId, status])
  @@map("plugin_projects")
}

model PluginTask {
  id          String    @id @default(cuid())
  projectId   String
  project     PluginProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  priority    String    @default("medium") // low, medium, high
  status      String    @default("todo")   // todo, in_progress, done
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([projectId])
  @@index([projectId, status])
  @@map("plugin_tasks")
}

// Language Tutor Plugin
model PluginLanguageSession {
  id                 String    @id @default(cuid())
  userId             String
  language           String                     // spanish, french, etc.
  level              String    @default("beginner") // beginner, intermediate, advanced
  score              Float     @default(0)
  exercisesCompleted Int       @default(0)
  startedAt          DateTime  @default(now())
  endedAt            DateTime?

  @@index([userId])
  @@index([userId, language])
  @@map("plugin_language_sessions")
}

// Phase 23: Collective Intelligence
model CollectivePattern {
  id          String   @id @default(cuid())
  
  patternType String   // topic_association, behavior_sequence, knowledge_correlation, preference_cluster, temporal_pattern
  domain      String
  trigger     String   @db.Text
  outcome     String   @db.Text
  
  frequency   Int      @default(1)
  confidence  Float    @default(0.5)
  sampleSize  Int      @default(1)
  metadata    Json     @default("{}")
  
  isPublished Boolean  @default(false) // Only true after MIN_GROUP_SIZE reached
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([patternType, domain])
  @@index([isPublished, confidence])
  @@index([createdAt])
  @@map("collective_patterns")
}

// Phase 25: Visual Identity and Presence
model VisualIdentity {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Core visual state
  primaryHue        Float    @default(220)   // 0-360 color wheel
  primarySaturation Float    @default(0.7)   // 0-1
  primaryLightness  Float    @default(0.6)   // 0-1
  secondaryHue      Float    @default(280)
  secondarySaturation Float  @default(0.5)
  secondaryLightness Float   @default(0.5)
  accentHue         Float    @default(45)
  
  // Visual style parameters
  style             String   @default("organic") // organic, geometric, minimal, expressive, cosmic
  complexity        Float    @default(0.5)   // 0-1, how detailed the visuals are
  animationSpeed    Float    @default(0.5)   // 0-1, how fast animations move
  symmetry          Float    @default(0.5)   // 0-1, balanced vs asymmetric
  
  // Expression parameters
  expressiveness    Float    @default(0.6)   // 0-1, how visually reactive
  glowIntensity     Float    @default(0.3)   // 0-1, aura/presence strength
  particleDensity   Float    @default(0.4)   // 0-1, ambient particle count
  formRigidity      Float    @default(0.3)   // 0-1, solid shape vs fluid
  
  // Relationship-driven visuals
  relationshipDepth Float    @default(0)     // 0-1, evolves with relationship
  trustGlow         Float    @default(0)     // 0-1, visual warmth from trust
  collaborationMarks Int     @default(0)     // visual marks from working together
  
  // Metadata
  generationCount   Int      @default(0)
  lastEvolutionEvent String?  // what triggered the last change
  lastEvolvedAt     DateTime @default(now())
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("visual_identities")
}
