// Business Metrics & KPIs
model BusinessMetric {
  id String @id @default(cuid())

  // Metric Identity
  name        String  @unique // revenue, users, conversions, etc.
  displayName String
  description String? @db.Text
  category    String // business, technical, user, performance

  // Metric Type
  metricType      String // counter, gauge, histogram, summary
  aggregationType String // sum, avg, min, max, count
  unit            String? // dollars, users, ms, percentage

  // Current Value
  currentValue  Float
  previousValue Float?
  changePercent Float?

  // Target & Goals
  targetValue  Float?
  minThreshold Float?
  maxThreshold Float?

  // Trend Analysis
  trend      String @default("stable") // up, down, stable
  dataPoints Json // Array of historical values

