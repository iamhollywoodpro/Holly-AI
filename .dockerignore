# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Next.js build artifacts ───────────────────────────────────────────────────
.next
out

# ── Node modules (installed fresh inside Docker) ──────────────────────────────
node_modules

# ── Environment files (secrets never go into image) ──────────────────────────
.env
.env.*
!.env.example

# ── Development / editor files ───────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────────────
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
jest.config.js

# ── Docs / CI ─────────────────────────────────────────────────────────────────
README.md
DEPLOY.md
CLAUDE.md
FEATURE_ROADMAP.md
HOLLY_IMPLEMENTATION_PLAN.md
HOLLY_MANIFESTO.md
PHASE_9_ARCHITECTURE.md
ORACLE_ARM_GUIDE.md
HOLLY_AI_COMPLETE_DOCUMENTATION.md
VERCEL.md
.github
.husky
docs/
mockups/
scratch/
*.md
!package.md

# ── PDFs and large files ──────────────────────────────────────────────────────
*.pdf
*.jpg
*.jpeg
*.gif
stitch-overview.png

# ── EXCEPT: Holly's avatar images (needed at runtime) ────────────────────────
!public/avatars/*.jpg
# Exclude old backups and poses (not referenced by code)
public/avatars/v2-backup/
public/avatars/poses/

# ── Large public assets (53MB of logo PNGs — not needed at runtime) ───────────
# Only favicon.png/favicon.svg/manifest.json are needed from public/
public/assets/
public/test-audio.html
public/api-docs.html
public/investor-pitch-deck.html
public/HOLLY_V2_3_MASTER_AUDIT.md

# ── Non-Docker sub-projects ──────────────────────────────────────────────────
browser-extension/
mobile-app/

# ── Scripts not needed at runtime ─────────────────────────────────────────────
scripts/

# ── Services not needed in main build ─────────────────────────────────────────
services/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Misc ──────────────────────────────────────────────────────────────────────
.eslintcache
*.tgz
.eslintrc.json
# docker/ is NOT excluded — startup.sh is copied into the image
