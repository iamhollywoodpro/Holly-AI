{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./",
    "noEmit": false,
    "incremental": false,
    "isolatedModules": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["holly-server.ts"],
  "exclude": ["node_modules", ".next", "src", "app", "pages"]
}
