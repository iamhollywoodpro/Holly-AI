# =============================================================================
# HOLLY MUSIC STUDIO - API CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and add your actual API keys
# DO NOT COMMIT .env.local TO VERSION CONTROL
# =============================================================================

# -----------------------------------------------------------------------------
# HOLLY TOOLS API - Autonomous Development & Deployment
# -----------------------------------------------------------------------------
# HOLLY Tools API gives HOLLY the ability to actually execute commands
# Deploy the Tools API first, then add these configuration values
# Get from: your Railway/Render deployment + CREDENTIALS.txt

# Tools API URL (from Railway deployment)
NEXT_PUBLIC_TOOLS_API_URL=https://your-holly-tools-api.railway.app

# Tools API Authentication (from CREDENTIALS.txt after deployment)
TOOLS_API_KEY=your_generated_api_key_here
TOOLS_API_SECRET=your_generated_api_secret_here

# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# -----------------------------------------------------------------------------
# DATABASE - NEON POSTGRESQL
# -----------------------------------------------------------------------------
# Get connection string from: https://neon.tech/dashboard
DATABASE_URL=postgresql://user:password@host/dbname

# -----------------------------------------------------------------------------
# VERCEL BLOB STORAGE
# -----------------------------------------------------------------------------
# Get token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_your_token_here

# -----------------------------------------------------------------------------
# MUSIC GENERATION - SUNOAPI.ORG (NOT Official Suno.ai)
# -----------------------------------------------------------------------------
# Get your API key from: https://sunoapi.org/dashboard
# API Documentation: https://sunoapi.org/docs
# Endpoints: /api/v1/generate, /api/v1/query
SUNO_API_KEY=your_sunoapi_org_key
SUNO_BASE_URL=https://api.sunoapi.org/api/v1

# -----------------------------------------------------------------------------
# AI LANGUAGE MODELS
# -----------------------------------------------------------------------------
# OpenAI - GPT models, embeddings, moderation
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key

# Anthropic - Claude models
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key

# =============================================================================
# PHASE 8A — SMART FREE MODEL ROUTER
# All keys below are 100% FREE tiers.  Add the ones you want; HOLLY will
# automatically cascade to the next available provider if one is rate-limited.
# =============================================================================

# ── Groq (SPEED — 300+ tok/s, 14,400 req/day FREE) ──────────────────────────
# Models: Llama 3.3 70B, Llama 3.1 8B, DeepSeek R1 70B
# Get key from: https://console.groq.com/keys  (no credit card needed)
# Route: speed/chat, fallback for all tasks
GROQ_API_KEY=gsk_your_groq_key

# ── Cloudflare Workers AI (CODING / AGENT — 256K ctx, FREE tier) ────────────
# Models: Kimi K2.5 (best free coder, launched Mar 2026), Llama 4 Scout, Qwen3-32B
# Get from: https://dash.cloudflare.com/ → Workers AI → API Tokens
# Free tier: ~10,000 neurons/month free, then $0.011/1k neurons
# Route: coding (primary), agent tasks
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_AI_TOKEN=your_cloudflare_ai_token

# ── NVIDIA NIM (REASONING — Qwen3 235B, DeepSeek R1, FREE) ──────────────────
# Models: Qwen3-235B-A22B (best free reasoning), DeepSeek R1, Llama 3.3 70B
# Get free key from: https://build.nvidia.com/  (click any model → Get API Key)
# Free tier: ~40 RPM, generous monthly quota
# Route: reasoning (primary), agent fallback
NVIDIA_API_KEY=nvapi-your_nvidia_nim_key

# ── OpenRouter (CREATIVE — 27 free models, 20 RPM / 200 RPD) ────────────────
# Free models: Qwen3 Coder 480B, Mistral Small 3.1 24B, Llama 3.3 70B, Gemma 3 27B
# Get key from: https://openrouter.ai/keys  (no credit card for free models)
# Route: creative writing, fallback pool for all tasks
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# ── Ollama (LOCAL — unlimited, zero cost, offline) ────────────────────────────
# Run locally: https://ollama.ai/download → ollama pull llama3.2
# Set OLLAMA_ENABLED=true to activate; OLLAMA_MODEL sets the default model
# Route: privacy-first, local inference, no rate limits
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google AI Studio key — kept ONLY for legacy integrations (speech/TTS).
# NOT used for chat routing. Chat uses Groq, CF, NVIDIA, OpenRouter, Ollama only.
GOOGLE_API_KEY=your_google_ai_studio_key

# Google Drive OAuth - For file storage integration
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: https://holly.nexamusicgroup.com/api/google-drive/callback
# 3. Enable Google Drive API
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://holly.nexamusicgroup.com/api/google-drive/callback

# -----------------------------------------------------------------------------
# VOICE & AUDIO — HOLLY's Primary Voice: Maya1 on Modal.com (FREE)
# -----------------------------------------------------------------------------
# ══════════════════════════════════════════════════════════════════════════════
# STEP 1: Deploy Maya1 to Modal.com (FREE $30/month tier)
#   cd services/maya1-tts && pip install modal && modal deploy modal_deploy.py
#
# STEP 2: Copy the endpoint URL from Modal dashboard → add below
#   URL format: https://iamhollywoodpro--holly-maya1-tts-generate.modal.run
# ══════════════════════════════════════════════════════════════════════════════

# Maya1 TTS Modal endpoint URL (from: modal deploy services/maya1-tts/modal_deploy.py)
HOLLY_MAYA1_TTS_URL=https://iamhollywoodpro--holly-maya1-tts-generate.modal.run

# Optional API key to protect your Modal endpoint (set same value in Modal Secrets)
HOLLY_TTS_API_KEY=your_optional_secret_key

# HOLLY's voice description — customize her voice here
MAYA1_VOICE_DESCRIPTION=Female voice in her 30s with an American accent. Confident, intelligent, warm tone with clear diction. Professional yet friendly, conversational pacing with emotional depth.

# Gemini TTS fallback (FREE) — used when Modal is unavailable
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ElevenLabs - (optional, not used for HOLLY's primary voice)
ELEVENLABS_API_KEY=your_elevenlabs_key

# Minimax - (optional, not used for HOLLY's primary voice)
MINIMAX_API_KEY=your_minimax_jwt_token

# -----------------------------------------------------------------------------
# VIDEO GENERATION
# -----------------------------------------------------------------------------
# Runway - AI video generation
# Get key from: https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=key_your_runway_api_key

# -----------------------------------------------------------------------------
# DEVELOPMENT & VERSION CONTROL
# -----------------------------------------------------------------------------
# GitHub Personal Access Token - For repository access, Actions, API
# Get token from: https://github.com/settings/tokens
# Scopes needed: repo, workflow, read:org
GITHUB_TOKEN=ghp_your_github_personal_access_token

# GitHub OAuth - For user repository integration
# Get credentials from: https://github.com/settings/developers
# 1. Create OAuth App
# 2. Add Authorization callback URL: https://holly.nexamusicgroup.com/api/github/callback
# 3. Scopes: repo, read:user, user:email
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Vercel - Deployment and hosting
# Get token from: https://vercel.com/account/tokens
# Permissions: Full Access (for deployments)
VERCEL_API_TOKEN=your_vercel_api_token
VERCEL_TEAM_ID=your_vercel_team_id_optional

# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# Next.js environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://holly.nexamusicgroup.com

# Application settings
NEXT_PUBLIC_APP_NAME=HOLLY
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_MUSIC_STUDIO_VERSION=1.0.0

# Feature flags
NEXT_PUBLIC_ENABLE_MUSIC_GENERATION=true
NEXT_PUBLIC_ENABLE_ARTIST_CREATION=true
NEXT_PUBLIC_ENABLE_VIDEO_GENERATION=true
NEXT_PUBLIC_ENABLE_LYRICS_AI=true

# Rate limiting (requests per minute)
RATE_LIMIT_MUSIC_GENERATION=10
RATE_LIMIT_ARTIST_GENERATION=20
RATE_LIMIT_LYRICS_GENERATION=30

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Add your API keys to .env.local
# 3. Deploy HOLLY Tools API first (see holly-tools-api folder)
# 4. Add Tools API credentials from CREDENTIALS.txt
# 5. Never commit .env.local to version control
# 6. Restart dev server after changes: npm run dev
#
# IMPORTANT: SunoAPI.org vs Official Suno.ai
# - We use SunoAPI.org (third-party API service)
# - NOT the official Suno.ai API
# - Get your key from https://sunoapi.org/dashboard
# =============================================================================

# ============================================
# Oracle Cloud AI Speech (MAYA1 Voice)
# ============================================
ORACLE_TENANCY_OCID=ocid1.tenancy.oc1..your-tenancy-ocid
ORACLE_USER_OCID=ocid1.user.oc1..your-user-ocid
ORACLE_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx
ORACLE_REGION=ca-toronto-1
ORACLE_PRIVATE_KEY_PATH=./oracle-private-key.pem
# ORACLE_COMPARTMENT_OCID=ocid1.compartment.oc1..your-compartment-ocid (optional)
