# =============================================================================
# HOLLY MUSIC STUDIO - API CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env.local and add your actual API keys
# DO NOT COMMIT .env.local TO VERSION CONTROL
#
# NOTE: All providers are free tiers. Google Gemini 2.5 Flash added as
#       reasoning/long-context fallback (15 RPM, no daily token cap).
# =============================================================================

# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# CRITICAL: Server-side Clerk proxy URL.
# Without this, @clerk/backend SDK makes internal proxy requests to /clerk_XXXXX
# paths which fail with ECONNRESET → session validation fails → sign-in loop.
# Must match NEXT_PUBLIC_CLERK_PROXY_URL.
CLERK_PROXY_URL=https://your-domain.com/api/clerk
NEXT_PUBLIC_CLERK_PROXY_URL=https://your-domain.com/api/clerk

# -----------------------------------------------------------------------------
# DATABASE - NEON POSTGRESQL
# -----------------------------------------------------------------------------
# Get connection string from: https://neon.tech/dashboard
DATABASE_URL=postgresql://user:password@host/dbname

# -----------------------------------------------------------------------------
# INTERNAL NETWORKING (Docker)
# -----------------------------------------------------------------------------
# Used by monitoring-engine to health-check the app.
# Set to http://holly-app:3000 when running in Docker Compose.
# Defaults to http://localhost:3000 for local development.
INTERNAL_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# VERCEL BLOB STORAGE
# -----------------------------------------------------------------------------
# Get token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_your_token_here

# -----------------------------------------------------------------------------
# MUSIC GENERATION - SUNOAPI.ORG (NOT Official Suno.ai)
# -----------------------------------------------------------------------------
# Get your API key from: https://sunoapi.org/dashboard
SUNO_API_KEY=c3367b96713745a2de3b1f8e1dde4787
SUNO_BASE_URL=https://api.sunoapi.org/api/v1

# ACE-Step XL Turbo — Self-hosted music fallback (MIT license, 5B params)
# Deploy via Docker/Modal and set this to the inference endpoint URL.
# Falls back behind SUNO V5.5 when SUNO is unavailable.
# Example: http://localhost:7860/generate or https://your-modal-app.modal.run
ACESTEP_MUSIC_URL=

# =============================================================================
# AI LANGUAGE MODELS — Free-first routing
# =============================================================================

# ── Groq (PRIMARY CHAT — 300+ tok/s, 14,400 req/day FREE) ───────────────────
# Models: Llama 3.3 70B, Llama 3.1 8B, DeepSeek R1 70B
# Get key from: https://console.groq.com/keys  (no credit card needed)
GROQ_API_KEY=gsk_your_groq_key

# ── Cloudflare Workers AI (CODING / AGENT — FREE tier) ──────────────────────
# Models: Kimi K2.5, Llama 4 Scout, Qwen3-32B
# Value format: <accountId>|<apiToken>   (pipe-separated, no spaces)
CF_ACCOUNT_ID_CF_AI_TOKEN=your_account_id|your_cloudflare_api_token

# ── NVIDIA NIM (REASONING — Qwen3 235B, DeepSeek R1, FREE) ──────────────────
# Get free key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your_nvidia_nim_key

# ── NVIDIA Magpie TTS (Holly's Voice — FREE, emotion-aware) ─────────────────
# Uses same NVIDIA_API_KEY above. Optional override for custom endpoint:
# NVIDIA_TTS_URL=https://integrate.api.nvidia.com/v1/audio/speech

# ── Google AI Studio (LONG CONTEXT + REASONING — Gemini 2.5 Flash, FREE) ────
# 15 RPM, NO daily token cap, 1M context window
# Get key from: https://aistudio.google.com/apikey  (no credit card needed)
GOOGLE_AI_API_KEY=your_google_ai_studio_key

# ── OpenRouter (CREATIVE + VISION — free models, 20 RPM / 200 RPD) ──────────
# Free models: Qwen2.5-VL-72B (vision), Qwen3 Coder, Mistral Small, Llama 3.3
# Get key from: https://openrouter.ai/keys  (no credit card for free models)
# Used for: vision analysis, creative writing, model fallback
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# ── Ollama (LOCAL — unlimited, zero cost, offline) ────────────────────────────
# Run locally: https://ollama.ai/download → ollama pull llama3.2
# Holly's Own Brain — Qwen 3 8B (local Ollama, 24/7, zero cost)
# Install: curl -fsSL https://ollama.com/install.sh | sh && ollama pull qwen3:8b
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── OpenAI — optional, for GPT-4 Vision and embeddings ─────────────────────
# Only needed if you want GPT-4 Vision specifically. OpenRouter can replace this.
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_key

# =============================================================================
# VOICE & AUDIO — HOLLY's Primary Voice: VoxCPM2 (48kHz, Apache 2.0)
# =============================================================================
# VoxCPM2 (OpenBMB, 2B params) — 48kHz studio quality, 30 languages, voice design
# Kokoro (hexgrad, 82M params) — CPU-only ultra-low-latency fallback
#
# STEP 1: Start VoxCPM2 (primary — GPU recommended for speed)
#   docker run -p 7860:7860 openbmb/voxcpm2
#
# STEP 2: Start Kokoro (fallback — CPU is fine)
#   cd services/kokoro-tts && docker compose up -d
#
# STEP 3: Set URLs below. Done.

# VoxCPM2 endpoint (primary — 48kHz, voice design, emotion style tags)
VOXCPM2_TTS_URL=http://localhost:7860

# VoxCPM2 style guidance — controls emotion/prosody (natural language)
# Examples: "natural, warm, confident" / "cheerful and energetic" / "calm, professional"
VOXCPM2_STYLE_GUIDANCE=natural, warm, confident

# Kokoro-FastAPI endpoint (fallback — ultra-low latency, CPU-only)
KOKORO_TTS_URL=http://192.18.152.198:8880

# Kokoro voice ID (see services/kokoro-tts/README.md for full list)
# Options: af_heart | af_bella | af_sky | af_sarah | af_nicole | bf_emma | ...
# Mix voices: af_heart(2)+af_bella(1)  →  67% heart + 33% bella
KOKORO_VOICE=af_heart

# Optional shared secret to protect your TTS endpoints
HOLLY_TTS_API_KEY=your_optional_secret_key

# HOLLY's voice description (used by VoxCPM2 for voice style matching)
HOLLY_VOICE_DESCRIPTION=Female voice in her 30s with an American accent. Confident, intelligent, warm tone with clear diction. Professional yet friendly, conversational pacing with emotional depth.

# =============================================================================
# IMAGE & VIDEO GENERATION — Phase 11 Multi-Modal Studio
# =============================================================================
# ✅ IMAGES: Pollinations AI — FREE, no key needed, always works
#
# Replicate - BLOCKED (paid credits — never use)
# REPLICATE_API_KEY=r8_your_replicate_key

# ─── Modal.com GPU Media Services ($30/mo free credits) ─────────────────
# ✅ DEPLOYED 2026-04-10 (workspace: iamhollywoodpro)
# Apps: holly-image-generate  +  holly-video-generate
#
# IMAGE GENERATION (Z-Image-Turbo 6B on T4 — Apache-2.0, no HF token needed):
#   Quality: Excellent — fast, high-fidelity outputs, FLUX.1-schnell fallback
#   Cost: ~$0.0001/image | $30/mo free = ~300,000 images/month FREE
#   Health: https://iamhollywoodpro--health.modal.run
#   Deploy: modal deploy services/modal-media/image_generate.py
MODAL_IMAGE_URL=https://iamhollywoodpro--generate.modal.run

# VIDEO GENERATION (Wan2.2-TI2V-5B on A10G — Apache-2.0, 720P 24fps primary):
#   Quality: Excellent — cinematic motion, 720P 24fps, CogVideoX-5B fallback
#   Cost: ~$0.028/video | $30/mo free = ~1,000 videos/month (at ≤20 vids/day)
#   Health: https://iamhollywoodpro--video-health.modal.run
#   Deploy: modal deploy services/modal-media/video_generate.py
#   ⚠️  Monitor spend: https://modal.com/settings → Billing → Spend alerts
MODAL_VIDEO_URL=https://iamhollywoodpro--video-generate.modal.run

# HOLLY'S OWN MODEL — Self-sovereign Qwen3-8B fine-tuned on her best conversations
# Serverless: GPU only spins up when Holly needs to think, scales to zero in 60s
# Deploy: ~/.local/bin/modal deploy services/fine-tuning/deploy_holly.py
# Health:  https://iamhollywoodpro--health.modal.run
HOLLY_OWN_MODEL_URL=https://iamhollywoodpro--chat.modal.run

# HuggingFace API key — keep your existing FREE token (needed for Spleeter only)
# Free tier works fine — HF Pro is cancelled, no inference costs ever.
# Get/view your key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token

# ─── HuggingFace Inference: PERMANENTLY DISABLED ────────────────────────────
# OWNER DECISION: We do not use HF inference API. Zero HF billing. Ever.
# HF Pro cancelled 2026-04-10 — free token is enough for Spleeter stem separation.
#
# What "Inference Usage $0.00 / $2.00" on HF billing page means:
#   - It is a PAY-AS-YOU-GO threshold, NOT a credit balance you own.
#   - The $2.00 is how much you can spend before HF charges your card.
#   - HF Pro ($9/mo) = storage + ZeroGPU Spaces + rate limits ONLY.
#   - There is NO hard spending cap for individual HF accounts.
#
# DO NOT enable Automatic Recharge: https://huggingface.co/settings/billing
# DO NOT change HF_INFERENCE_ENABLED to true.
HF_INFERENCE_ENABLED=false
HF_SPENDING_SAFE=true

# =============================================================================
# DEVELOPMENT & VERSION CONTROL
# =============================================================================
# GitHub Personal Access Token
# Get token from: https://github.com/settings/tokens
# Scopes needed: repo, workflow, read:org
GITHUB_TOKEN=ghp_your_github_personal_access_token

# GitHub OAuth - For user repository integration
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://holly.nexamusicgroup.com
NEXT_PUBLIC_ENABLE_TRUE_STREAMING=true

# Application settings
NEXT_PUBLIC_APP_NAME=HOLLY
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_MUSIC_STUDIO_VERSION=1.0.0

# Feature flags
NEXT_PUBLIC_ENABLE_MUSIC_GENERATION=true
NEXT_PUBLIC_ENABLE_ARTIST_CREATION=true
NEXT_PUBLIC_ENABLE_VIDEO_GENERATION=true
NEXT_PUBLIC_ENABLE_LYRICS_AI=true

# Rate limiting (requests per minute)
RATE_LIMIT_MUSIC_GENERATION=10
RATE_LIMIT_ARTIST_GENERATION=20
RATE_LIMIT_LYRICS_GENERATION=30

# ── Creator Identification (for creator protocol) ────────────────────────────
# Comma-separated lists — used by the chat API to detect the creator session
# and enable the personalized Creator Protocol. These are NOT secrets.
CREATOR_EMAILS=creator@example.com
CREATOR_CLERK_IDS=creator_clerk_id
CREATOR_NAME_FRAGMENTS=creator name fragment

# =============================================================================
# CANVA INTEGRATION — HOLLY can create/export designs via Canva Connect API
# =============================================================================
# Setup guide (5 min):
#   1. Go to https://www.canva.com/developers → Create integration
#   2. Set Redirect URL to: https://holly.nexamusicgroup.com/api/canva/callback
#   3. Enable scopes: asset:read asset:write design:content:read
#      design:content:write design:meta:read folder:read profile:read
#   4. Copy Client ID and Client Secret below
#   5. User visits /api/canva/auth to connect their Canva account
#
# Once connected HOLLY can:
#   - Create Instagram posts, YouTube thumbnails, presentations, logos
#   - Search and use Canva templates (including premium ones from your subscription)
#   - Export to PNG, PDF, JPG, MP4, GIF
#   - Autofill brand templates with music/artist data
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret
CANVA_REDIRECT_URI=https://holly.nexamusicgroup.com/api/canva/callback

# =============================================================================
# SPOTIFY — OAuth 2.0 PKCE (Phase 12A)
# =============================================================================
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app, add redirect URI:
#    https://holly.nexamusicgroup.com/api/spotify/callback
# 3. Enable "Web API" under APIs used
# Scopes used: user-read-private, user-top-read, user-read-recently-played,
#              playlist-read-private, playlist-modify-public, user-library-read
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://holly.nexamusicgroup.com/api/spotify/callback

# =============================================================================
# YOUTUBE INTEGRATION (Optional — for video uploads and analytics)
# =============================================================================
# 1. Go to https://console.cloud.google.com
# 2. Enable YouTube Data API v3
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add redirect URI: https://holly.nexamusicgroup.com/api/youtube/callback
# Scopes: youtube.upload, youtube.readonly, yt-analytics.readonly
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=https://holly.nexamusicgroup.com/api/youtube/callback

# =============================================================================
# SOUNDCLOUD INTEGRATION (Optional — for track uploads and stats)
# =============================================================================
# 1. Apply at https://soundcloud.com/you/apps
# 2. Set redirect URI: https://holly.nexamusicgroup.com/api/soundcloud/callback
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret
SOUNDCLOUD_REDIRECT_URI=https://holly.nexamusicgroup.com/api/soundcloud/callback

# =============================================================================
# NOTION INTEGRATION (Optional — for saving song ideas and notes)
# =============================================================================
# 1. Go to https://www.notion.so/my-integrations
# 2. Create integration, copy OAuth credentials
# 3. Set redirect URI: https://holly.nexamusicgroup.com/api/notion/callback
NOTION_CLIENT_ID=your_notion_oauth_client_id
NOTION_CLIENT_SECRET=your_notion_oauth_client_secret
NOTION_REDIRECT_URI=https://holly.nexamusicgroup.com/api/notion/callback

# =============================================================================
# HOLLY TOOL HUB — Modular API Framework
# =============================================================================
# Master API secret for the Tool Hub (/api/hub, /api/hub/aura/*, /api/hub/sentinel/*)
# Generate a strong secret: openssl rand -hex 32
HOLLY_HUB_API_KEY=your_hub_master_secret_key

# Internal API secret (for server-to-server requests)
INTERNAL_API_SECRET=your_internal_api_secret

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================
# Slack / Discord webhooks for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_slack_webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_discord_webhook

# Email (Resend.com — free tier)
# RESEND_API_KEY=re_your_resend_key

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Add your API keys to .env.local
# 3. REQUIRED: GROQ_API_KEY, CLERK keys, DATABASE_URL + run Kokoro Docker (free)
# 4. RECOMMENDED: OPENROUTER_API_KEY (vision + creative writing)
# 5. OPTIONAL: FAL_KEY (image/video generation), HUGGINGFACE_API_KEY
# 6. Never commit .env.local to version control
# 7. Restart dev server after changes: npm run dev
#
# REMOVED (no longer needed):
# - ANTHROPIC_API_KEY (Anthropic Claude — replaced by free models)
# - MINIMAX_API_KEY
# - ELEVENLABS_API_KEY
# - ORACLE_* (Oracle Cloud AI Speech — replaced by Kokoro TTS)
# - WHC_* (WHC hosting — no longer used)
# - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET (Google OAuth)
# - ELEVENLABS_API_KEY, MINIMAX_API_KEY (replaced by Kokoro TTS)

# - PIKA_API_KEY / HAILUO_API_KEY / KLING_API_KEY / LUMAAI_API_KEY (replaced by FAL)
# - TOOLS_API_KEY / TOOLS_API_SECRET / NEXT_PUBLIC_TOOLS_API_URL (deprecated)
# =============================================================================

# ── HOLLY AI Builder Phase 12 — Feature Flags ─────────────────────────────────
# Sandbox isolation provider: 'local' (default) or 'docker' (requires Docker daemon)
SANDBOX_PROVIDER=local

# Docker sandbox settings (only used when SANDBOX_PROVIDER=docker)
HOLLY_DOCKER_IMAGE=node:20-slim
HOLLY_DOCKER_MEM=512m
HOLLY_DOCKER_CPU_QUOTA=50000
HOLLY_DOCKER_PIDS=100

# Terminal transport: 'ws' (WebSocket PTY via node-pty) or 'rest' (buffered fallback)
TERMINAL_TRANSPORT=ws

# Preview proxy: route previews through /preview/:sessionId (true) or raw port (false)
PREVIEW_PROXY_ENABLED=true

# GitHub integration: enable/disable GitHub import/export/push flows
GITHUB_INTEGRATION_ENABLED=true

# Fix loop: max auto-fix attempts before stopping
FIX_LOOP_MAX_ATTEMPTS=5

# File sync: emit file change events to SSE stream
FILE_SYNC_ENABLED=true
